<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<title>PresAI — Presupuesto de Obra</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap');
:root {
    --navy: #1e3a5f; --navy-lt: #e8eef7; --border: #e2e8f0; --bg: #f1f5f9;
}
body { font-family: 'IBM Plex Sans', sans-serif; background: var(--bg); font-size: 13px; }
#rotate-warning {
    display: none; position: fixed; inset: 0; background: var(--navy); color: white;
    z-index: 9999; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 20px;
}
@media screen and (orientation: portrait) and (max-width: 1024px) {
    #rotate-warning { display: flex; }
    .app-container { display: none; }
}
.tab-on { color: var(--navy); border-bottom: 2px solid var(--navy); }
input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; }
</style>
</head>
<body>

<div id="rotate-warning">
    <h2 class="text-xl font-bold mb-2">Gira tu dispositivo</h2>
    <p>Usa tu celular en modo horizontal para una mejor experiencia.</p>
</div>

<div class="app-container min-h-screen flex flex-col">
    <!-- HEADER ORIGINAL -->
    <header class="bg-[#1e3a5f] text-white p-3 shadow-lg flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-3">
            <div class="bg-white/10 p-2 rounded-lg border border-white/20">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            </div>
            <div>
                <div class="text-lg font-bold leading-none">Pres<span class="text-blue-300">AI</span></div>
                <div class="text-[9px] opacity-50 font-mono">CONSTRUCCIÓN CIVIL</div>
            </div>
        </div>
        <div class="flex gap-2">
            <button class="bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded text-[10px] font-bold transition-all">PROYECTOS</button>
            <button class="bg-green-600 hover:bg-green-700 px-3 py-1.5 rounded text-[10px] font-bold transition-all">GUARDAR</button>
        </div>
    </header>

    <!-- TABS -->
    <nav class="bg-white border-b border-slate-200 flex px-4 overflow-x-auto no-scrollbar">
        <button onclick="showTab('bud')" id="btn-bud" class="tab-btn px-4 py-3 text-[10px] font-bold uppercase tracking-wider tab-on">Presupuesto</button>
        <button onclick="showTab('gg')" id="btn-gg" class="tab-btn px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-400">Gastos Generales</button>
        <button onclick="showTab('apu')" id="btn-apu" class="tab-btn px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-400">Análisis Unitarios</button>
        <button onclick="showTab('cub')" id="btn-cub" class="tab-btn px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-400">Cubicaciones</button>
    </nav>

    <!-- CONTENIDO -->
    <main class="p-4 max-w-6xl mx-auto w-full flex-1">
        <!-- Pestaña Presupuesto (Simulada para mantener estructura) -->
        <div id="tab-bud" class="tab-content">
            <div class="bg-white p-4 rounded-lg border border-slate-200 shadow-sm mb-4 grid grid-cols-2 gap-4">
                <div class="col-span-2"><label class="text-[9px] font-bold text-slate-400 uppercase">Obra</label><input class="w-full bg-slate-50 border p-2 rounded mt-1" placeholder="Nombre del proyecto..."></div>
            </div>
            <div class="text-center py-10 text-slate-400 italic">Área de presupuesto activa</div>
        </div>

        <!-- Pestaña Gastos Generales (MEJORADA) -->
        <div id="tab-gg" class="tab-content hidden space-y-6">
            <div id="gg-sections">
                <!-- Las secciones se añaden aquí -->
            </div>

            <!-- Botón Agregar Campo Dinámico -->
            <div class="flex justify-center pt-4 relative">
                <div class="relative inline-block text-left">
                    <button onclick="toggleGGMenu()" class="bg-[#1e3a5f] text-white px-6 py-2.5 rounded-full font-bold text-[11px] uppercase tracking-widest shadow-xl flex items-center gap-2 hover:scale-105 transition-all">
                        Agregar Campo 🔻
                    </button>
                    <div id="gg-menu" class="hidden absolute bottom-full mb-2 left-1/2 -translate-x-1/2 w-56 bg-white rounded-xl shadow-2xl border border-slate-200 overflow-hidden z-50">
                        <div id="gg-options" class="max-h-60 overflow-y-auto py-1">
                            <!-- Opciones dinámicas -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Otras pestañas -->
        <div id="tab-apu" class="tab-content hidden text-center py-20 text-slate-300">Módulo de Análisis Unitarios</div>
        <div id="tab-cub" class="tab-content hidden text-center py-20 text-slate-300">Módulo de Cubicaciones</div>
    </main>

    <!-- FOOTER CON TOTALES -->
    <footer class="bg-white border-t border-slate-200 p-4 sticky bottom-0 flex justify-end items-center gap-6 shadow-[0_-10px_20px_rgba(0,0,0,0.05)]">
        <div class="text-right">
            <div class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Total Gastos Generales</div>
            <div id="total-gg-global" class="text-xl font-black text-[#1e3a5f]">$ 0</div>
        </div>
    </footer>
</div>

<script>
// --- LÓGICA DE NAVEGACIÓN ---
function showTab(id) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
    document.getElementById('tab-' + id).classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('tab-on', 'text-slate-400'));
    document.getElementById('btn-' + id).classList.add('tab-on');
}

// --- LÓGICA DE GASTOS GENERALES ---
const CATEGORIES = ['Personal supervisión', 'Personal técnico', 'Maquinaria y equipos', 'Elementos de seguridad', 'Consumos de obra', 'Herramientas menores', 'Gastos zonales', 'Gastos de oficina central', 'Gastos financiero', 'Otros'];
let activeCategories = ['Otros'];
let ggData = [];

function toggleGGMenu() {
    const menu = document.getElementById('gg-menu');
    menu.classList.toggle('hidden');
    if(!menu.classList.contains('hidden')) renderGGOptions();
}

function renderGGOptions() {
    const container = document.getElementById('gg-options');
    const available = CATEGORIES.filter(c => !activeCategories.includes(c));
    container.innerHTML = available.map(c => `
        <button onclick="addCategory('${c}')" class="w-full text-left px-4 py-2.5 text-[11px] hover:bg-blue-50 hover:text-blue-600 border-b border-slate-50 last:border-none transition-colors">${c}</button>
    `).join('') || '<div class="p-4 text-[10px] text-slate-400 italic text-center">No hay más categorías</div>';
}

function addCategory(name) {
    activeCategories.push(name);
    document.getElementById('gg-menu').classList.add('hidden');
    renderGGSections();
}

function removeCategory(name) {
    if(confirm(`¿Eliminar sección "${name}"?`)) {
        activeCategories = activeCategories.filter(c => c !== name);
        ggData = ggData.filter(d => d.cat !== name);
        renderGGSections();
    }
}

function addRow(cat) {
    ggData.push({ id: Date.now(), cat, desc: '', unit: 'mes', qty: 1, time: 1, price: 0 });
    renderGGSections();
}

function updateVal(id, field, val) {
    const item = ggData.find(d => d.id === id);
    if(item) {
        item[field] = field === 'desc' || field === 'unit' ? val : parseFloat(val) || 0;
        renderGGSections();
    }
}

function renderGGSections() {
    const container = document.getElementById('gg-sections');
    let totalGlobal = 0;

    container.innerHTML = activeCategories.map(cat => {
        const items = ggData.filter(d => d.cat === cat);
        const subtotal = items.reduce((acc, i) => acc + (i.qty * i.time * i.price), 0);
        totalGlobal += subtotal;

        return `
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden mb-6">
                <div class="bg-slate-50 p-3 border-b border-slate-200 flex justify-between items-center">
                    <h3 class="text-[11px] font-bold text-[#1e3a5f] uppercase tracking-wider">${cat}</h3>
                    <button onclick="removeCategory('${cat}')" class="text-red-400 hover:text-red-600 text-[10px] font-bold">ELIMINAR SECCIÓN ×</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-[11px]">
                        <thead class="bg-slate-50/50 text-slate-400 font-bold uppercase border-b border-slate-100">
                            <tr>
                                <th class="p-2 text-left">Descripción</th>
                                <th class="p-2 text-center w-16">Unid</th>
                                <th class="p-2 text-right w-16">Cant.</th>
                                <th class="p-2 text-right w-20 bg-blue-50 text-blue-600">Tiempo Uso</th>
                                <th class="p-2 text-right w-24">Precio</th>
                                <th class="p-2 text-right w-28">Subtotal</th>
                                <th class="p-2 w-8"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            ${items.map(i => `
                                <tr>
                                    <td class="p-1.5"><input oninput="updateVal(${i.id}, 'desc', this.value)" value="${i.desc}" class="w-full bg-transparent outline-none p-1" placeholder="Ej: Jefe de Obra"></td>
                                    <td class="p-1.5"><input oninput="updateVal(${i.id}, 'unit', this.value)" value="${i.unit}" class="w-full bg-transparent outline-none p-1 text-center"></td>
                                    <td class="p-1.5"><input type="number" oninput="updateVal(${i.id}, 'qty', this.value)" value="${i.qty}" class="w-full bg-transparent outline-none p-1 text-right font-mono"></td>
                                    <td class="p-1.5 bg-blue-50/20"><input type="number" oninput="updateVal(${i.id}, 'time', this.value)" value="${i.time}" class="w-full bg-transparent outline-none p-1 text-right font-mono text-blue-600 font-bold"></td>
                                    <td class="p-1.5"><input type="number" oninput="updateVal(${i.id}, 'price', this.value)" value="${i.price}" class="w-full bg-transparent outline-none p-1 text-right font-mono"></td>
                                    <td class="p-1.5 text-right font-mono font-bold text-slate-600">$ ${(i.qty * i.time * i.price).toLocaleString('es-CL')}</td>
                                    <td class="p-1.5 text-center"><button onclick="ggData = ggData.filter(d => d.id !== ${i.id}); renderGGSections();" class="text-slate-300 hover:text-red-500">×</button></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                <div class="p-2 bg-slate-50/50 border-t border-slate-100 flex justify-between items-center px-4">
                    <button onclick="addRow('${cat}')" class="text-blue-600 font-bold text-[9px] uppercase tracking-widest hover:underline">+ AGREGAR GASTO</button>
                    <div class="text-[11px] font-bold text-[#1e3a5f]">Subtotal: $ ${subtotal.toLocaleString('es-CL')}</div>
                </div>
            </div>
        `;
    }).join('');

    document.getElementById('total-gg-global').textContent = '$ ' + totalGlobal.toLocaleString('es-CL');
}

// Inicializar
renderGGSections();
</script>
</body>
</html>
